{
  "name": "NodePulse",
  "version": "1.0.0",
  "slug": "nodepulse",
  "description": "Comprehensive dashboard and integration for monitoring Meshtastic networks directly within Home Assistant",
  "url": "https://github.com/garethmo/NodePulse",
  "arch": ["aarch64", "amd64", "armhf", "armv7", "i386"],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "ingress": true,
  "ingress_port": 8099,
  "ports": {
    "8099/tcp": 8099
  },
  "panel_icon": "mdi:radio-tower",
  "panel_title": "NodePulse",
  "options": {
    "log_level": "info",
    "connection_type": "direct",
    "meshtastic_host": "192.168.1.100",
    "meshtastic_port": 4403,
    "proxy_host": "",
    "proxy_port": 4403,
    "access_key": "",
    "scan_interval": 30,
    "ignored_nodes": [],
    "ha_base_url": "http://homeassistant:8123",
    "disable_token_validation": true
  },
  "schema": {
    "log_level": "list(trace|debug|info|notice|warning|error|fatal)",
    "connection_type": "list(direct|proxy)",
    "meshtastic_host": "str",
    "meshtastic_port": "port",
    "proxy_host": "str?",
    "proxy_port": "port",
    "access_key": "str?",
    "scan_interval": "int(10,300)",
    "ignored_nodes": ["str?"],
    "ha_base_url": "str?",
    "disable_token_validation": "bool?"
  },
  "map": {},
  "environment": {}
}
