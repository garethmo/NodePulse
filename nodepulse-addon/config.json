{
  "name": "NodePulse",
  "version": "0.1.0",
  "slug": "nodepulse",
  "description": "Monitor Meshtastic mesh network health — nodes, signal metrics, GPS mapping, and encrypted direct messaging.",
  "url": "https://github.com/garethmo/NodePulse",
  "arch": ["aarch64", "amd64", "armhf", "armv7", "i386"],
  "startup": "application",
  "boot": "auto",
  "ingress": true,
  "ingress_port": 8099,
  "panel_icon": "mdi:radio-tower",
  "panel_title": "NodePulse",
  "options": {
    "meshtastic_host": "192.168.1.100",
    "meshtastic_port": 4403,
    "access_key": "",
    "scan_interval": 30,
    "ignored_nodes": []
  },
  "schema": {
    "meshtastic_host": "str",
    "meshtastic_port": "port",
    "access_key": "str?",
    "scan_interval": "int(10,300)",
    "ignored_nodes": ["str?"]
  },
  "map": {},
  "ports": {},
  "environment": {},
  "image": "ghcr.io/garethmo/nodepulse-addon/{arch}"
}
